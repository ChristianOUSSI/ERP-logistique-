# ============================================================
# Variables d'environnement Frontend - KAMLOG EM-ERP
# Copiez ce fichier en .env.local et remplissez les valeurs
# ============================================================

# --- API Backend FastAPI ---
# LOCAL: http://localhost:8000
# PRODUCTION (Railway): https://[votre-service].up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- NextAuth ---
# LOCAL: http://localhost:3000
# PRODUCTION (Vercel): https://kamlog.vercel.app
NEXTAUTH_URL=http://localhost:3000
# Générer avec: openssl rand -base64 32
NEXTAUTH_SECRET=kamlog_nextauth_secret_change_in_prod_min_32_chars

# --- App Info ---
NEXT_PUBLIC_APP_NAME=KAMLOG EM-ERP
NEXT_PUBLIC_APP_VERSION=1.0.0