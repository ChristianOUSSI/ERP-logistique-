# ============================================================
# Variables d'environnement Railway - KAMLOG EM-ERP
# Copiez ces valeurs dans votre projet Railway
# ============================================================

# ─── Base de données PostgreSQL (Railway Plugin) ─────────────
# Railway fournira automatiquement DATABASE_URL via le plugin PostgreSQL
# Vous n'avez pas besoin de configurer manuellement ces variables

# ─── Redis (Railway Plugin) ─────────────────────────────────
# Railway fournira automatiquement REDIS_URL via le plugin Redis
# Vous n'avez pas besoin de configurer manuellement ces variables

# ─── JWT Auth (Générez avec generate_secrets.py) ─────────────
JWT_SECRET_KEY=CHANGE_ME_execute_python_generate_secrets_py
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── MinIO (Optionnel - ou utilisez Railway Disk) ───────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=kamlog_minio
MINIO_SECRET_KEY=CHANGE_ME_execute_python_generate_secrets_py
MINIO_BUCKET_DOCUMENTS=kamlog-documents
MINIO_SECURE=false

# ─── Email (Optionnel) ───────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@kamlog.cm
SMTP_PASSWORD=CHANGE_ME_your_gmail_app_password
SMTP_FROM=KAMLOG ERP <noreply@kamlog.cm>

# ─── Application ─────────────────────────────────────────────
APP_NAME=KAMLOG EM-ERP
APP_VERSION=1.0.0
DEBUG=false
ALLOWED_ORIGINS=https://kamlog.vercel.app,http://localhost:3000

# ─── Seeders (Exécuter automatiquement au démarrage) ─────────
SEED_DATA=true

# ─── Celery (Utilisez l'URL Redis Railway) ───────────────────
# Railway fournira automatiquement REDIS_URL
# Configurez ces variables en utilisant REDIS_URL:
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}
