# ============================================================
# .env  Variables d'Environnement KAMLOG EM-ERP
# CONFIDENTIEL  Ne jamais committer ce fichier
# ============================================================

# ─── Base de données PostgreSQL 17 ────────────────────────
DB_NAME=kamlog_erp
DB_USER=kamlog
DB_PASSWORD=CHANGE_ME_secure_password_2026
DATABASE_URL=postgresql+asyncpg://kamlog:CHANGE_ME@localhost:5432/kamlog_erp

# ─── Redis ────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_URL=redis://:CHANGE_ME_redis_password@localhost:6379/0

# ─── JWT Auth ─────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_super_secret_jwt_key_min_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── MinIO (Stockage PDF) ─────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=kamlog_minio
MINIO_SECRET_KEY=CHANGE_ME_minio_secret
MINIO_BUCKET_DOCUMENTS=kamlog-documents
MINIO_SECURE=false

# ─── Email (pour notifications) ───────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@kamlog.cm
SMTP_PASSWORD=CHANGE_ME_email_password
SMTP_FROM=KAMLOG ERP <noreply@kamlog.cm>

# ─── Application ──────────────────────────────────────────
APP_NAME=KAMLOG EM-ERP
APP_VERSION=1.0.0
DEBUG=false
ALLOWED_ORIGINS=["http://localhost:3000","https://kamlog-erp.cm"]

# ─── Frontend (Next.js) ───────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=CHANGE_ME_nextauth_secret

# ─── Celery ───────────────────────────────────────────────
CELERY_BROKER_URL=redis://:CHANGE_ME_redis_password@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:CHANGE_ME_redis_password@localhost:6379/2
